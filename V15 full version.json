{"files":[{"id":"a3910608-d584-4b95-8a42-a0ae5b5dfc12","name":"appsscript","type":"json","source":"{\n  \"timeZone\": \"Asia/Jakarta\",\n  \"dependencies\": {},\n  \"exceptionLogging\": \"STACKDRIVER\",\n  \"runtimeVersion\": \"V8\",\n  \"webapp\": {\n    \"executeAs\": \"USER_DEPLOYING\",\n    \"access\": \"ANYONE_ANONYMOUS\"\n  }\n}"},{"id":"49e90dc5-2beb-4e97-93ee-de4c34674e7c","name":"Kode","type":"server_js","source":"/**\n * CORE-INV V15.0 - PLATINUM OMNI\n * Sync 30s | Auto-Move | Email Label NEW\n */\n\nconst CONFIG \u003d {\n  FILE_NAME: \"DATA BASE V1\",\n  SHEET_LOG: \"TRANSAKSI_LOG\",\n  SHEET_PIC: \"PIC\",\n  SHEET_AUTH: \"LOGIN_HISTORY\",\n  SHEET_HISTORY: \"RIWAYAT_TINDAKAN\",\n  RECIPIENTS: \"fauziarrasyidhadi@gmail.com,irmanurha285@gmail.com,ragilrahman546@gmail.com,okegi603@gmail.com\"\n};\n\nfunction doGet() {\n  return HtmlService.createTemplateFromFile(\u0027Index\u0027).evaluate()\n    .setTitle(\u0027Inventory Controller\u0027)\n    .addMetaTag(\u0027viewport\u0027, \u0027width\u003ddevice-width, initial-scale\u003d1, maximum-scale\u003d1, user-scalable\u003dno\u0027)\n    .setXFrameOptionsMode(HtmlService.XFrameOptionsMode.ALLOWALL);\n}\n\nfunction getSpreadsheet() {\n  const files \u003d DriveApp.getFilesByName(CONFIG.FILE_NAME);\n  if (files.hasNext()) return SpreadsheetApp.open(files.next());\n  throw new Error(\"File \u0027\" + CONFIG.FILE_NAME + \"\u0027 tidak ditemukan!\");\n}\n\nfunction checkLogin(email) {\n  const ss \u003d getSpreadsheet();\n  const sheet \u003d ss.getSheetByName(CONFIG.SHEET_PIC);\n  const data \u003d sheet.getDataRange().getValues();\n  const inputEmail \u003d email.toLowerCase().trim();\n  const isValid \u003d data.some(row \u003d\u003e row[0] \u0026\u0026 row[0].toString().toLowerCase().trim() \u003d\u003d\u003d inputEmail);\n  \n  if (isValid) {\n    const authSheet \u003d ss.getSheetByName(CONFIG.SHEET_AUTH) || ss.insertSheet(CONFIG.SHEET_AUTH);\n    authSheet.appendRow([new Date(), inputEmail, \"Login Success\"]);\n    return { success: true, email: inputEmail };\n  }\n  return { success: false };\n}\n\nfunction getDashboardData() {\n  const ss \u003d getSpreadsheet();\n  const sheet \u003d ss.getSheetByName(CONFIG.SHEET_LOG);\n  const values \u003d sheet.getDataRange().getValues();\n  const disp \u003d sheet.getDataRange().getDisplayValues();\n  const today \u003d new Date();\n  today.setHours(0,0,0,0);\n  \n  let results \u003d { under90: [], over90: [], stats: { p30: 0, p50: 0, p70: 0, tarik: 0 }, chartCat3: {} };\n  let newEntries \u003d [];\n\n  for (let i \u003d 1; i \u003c values.length; i++) {\n    let row \u003d values[i];\n    if (row[0] !\u003d\u003d \"\" \u0026\u0026 row[8] instanceof Date) {\n      const expDate \u003d new Date(row[8]);\n      const diffTime \u003d expDate - today;\n      const daysLeft \u003d Math.ceil(diffTime / (1000 * 60 * 60 * 24));\n      \n      // Label NEW Logic (3 hari pertama)\n      const dateIn \u003d new Date(row[0]);\n      const isNew \u003d (today - dateIn) / (1000 * 60 * 60 * 24) \u003c\u003d 3;\n      if (isNew) newEntries.push(disp[i][4]);\n\n      const hNormal \u003d parseFloat(row[7]) || 0;\n      let diskon \u003d 0, label \u003d \"AMAN\";\n\n      if (daysLeft \u003c\u003d 0) { diskon \u003d 100; label \u003d \"TARIK\"; results.stats.tarik++; }\n      else if (daysLeft \u003c\u003d 30) { diskon \u003d 70; label \u003d \"70% OFF\"; results.stats.p70++; }\n      else if (daysLeft \u003c\u003d 60) { diskon \u003d 50; label \u003d \"50% OFF\"; results.stats.p50++; }\n      else if (daysLeft \u003c\u003d 90) { diskon \u003d 30; label \u003d \"30% OFF\"; results.stats.p30++; }\n\n      let item \u003d {\n        row: i + 1, barcode: disp[i][2], nama: disp[i][4], cat3: disp[i][1],\n        qty: disp[i][6], exp: disp[i][8], sisa: daysLeft, hNormal: hNormal,\n        hPromo: hNormal - (hNormal * diskon / 100), label: label, isNew: isNew\n      };\n\n      if (daysLeft \u003c\u003d 90) results.under90.push(item);\n      else results.over90.push(item);\n\n      if(item.cat3) results.chartCat3[item.cat3] \u003d (results.chartCat3[item.cat3] || 0) + 1;\n    }\n  }\n\n  // Trigger Email for New Data\n  if(newEntries.length \u003e 0) {\n    const key \u003d \"MAIL_\" + newEntries.length + \"_\" + today.toDateString();\n    if(PropertiesService.getScriptProperties().getProperty(\u0027LAST_MAIL\u0027) !\u003d\u003d key) {\n      MailApp.sendEmail(CONFIG.RECIPIENTS, \"⚠️ DATA BARU [NEW] MASUK\", \"Halo, ada \" + newEntries.length + \" data baru berlabel NEW hari ini.\");\n      PropertiesService.getScriptProperties().setProperty(\u0027LAST_MAIL\u0027, key);\n    }\n  }\n  return results;\n}\n\nfunction moveAction(rowId, action, user) {\n  const ss \u003d getSpreadsheet();\n  const logSheet \u003d ss.getSheetByName(CONFIG.SHEET_LOG);\n  const histSheet \u003d ss.getSheetByName(CONFIG.SHEET_HISTORY) || ss.insertSheet(CONFIG.SHEET_HISTORY);\n  const data \u003d logSheet.getRange(rowId, 1, 1, logSheet.getLastColumn()).getValues()[0];\n  histSheet.appendRow([...data, action, new Date(), user]);\n  logSheet.deleteRow(rowId);\n  return true;\n}"},{"id":"78f9589e-86e8-479c-9108-829e5f1af181","name":"Index","type":"html","source":"\u003c!DOCTYPE html\u003e\n\u003chtml lang\u003d\"id\"\u003e\n\u003chead\u003e\n  \u003cmeta charset\u003d\"UTF-8\"\u003e\n  \u003cscript src\u003d\"https://cdn.tailwindcss.com\"\u003e\u003c/script\u003e\n  \u003cscript src\u003d\"https://cdn.jsdelivr.net/npm/chart.js\"\u003e\u003c/script\u003e\n  \u003clink rel\u003d\"stylesheet\" href\u003d\"https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css\"/\u003e\n  \u003clink rel\u003d\"stylesheet\" href\u003d\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css\"\u003e\n  \u003cstyle\u003e\n    @import url(\u0027https://fonts.googleapis.com/css2?family\u003dPlus+Jakarta+Sans:wght@400;600;800\u0026display\u003dswap\u0027);\n    :root { --bg: #f8fafc; --card: #ffffff; --text: #0f172a; }\n    .dark { --bg: #0f172a; --card: #1e293b; --text: #f8fafc; }\n    body { font-family: \u0027Plus Jakarta Sans\u0027, sans-serif; background: var(--bg); color: var(--text); transition: 0.3s; }\n    .sidebar { width: 260px; transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1); }\n    .sidebar.collapsed { width: 70px; }\n    .sidebar.collapsed .hide-text { display: none; opacity: 0; }\n    .card { background: var(--card); }\n    @media print { .no-print { display: none !important; } main { margin: 0 !important; } td, th { font-size: 8px !important; padding: 2px !important; border: 0.5px solid #ddd !important; } }\n  \u003c/style\u003e\n\u003c/head\u003e\n\u003cbody class\u003d\"flex h-screen overflow-hidden\"\u003e\n\n  \u003cdiv id\u003d\"login-overlay\" class\u003d\"fixed inset-0 z-[100] bg-slate-900 flex items-center justify-center p-6 transition-all duration-700\"\u003e\n    \u003cdiv class\u003d\"w-full max-w-sm card p-10 rounded-[2.5rem] shadow-2xl text-center animate__animated animate__zoomIn\"\u003e\n      \u003cdiv class\u003d\"w-20 h-20 bg-red-600 rounded-3xl mx-auto flex items-center justify-center mb-6 shadow-xl shadow-red-500/40 rotate-12\"\u003e\u003ci class\u003d\"fas fa-shield-alt text-white text-3xl\"\u003e\u003c/i\u003e\u003c/div\u003e\n      \u003ch2 class\u003d\"text-2xl font-black italic mb-8\"\u003eLOGIN DOLO BOS!!!! \u003cspan class\u003d\"text-red-300\"\u003eHABIS LOGIN REFSRESH BIAR GAK BLANK\u003c/span\u003e\u003c/h2\u003e\n      \u003cinput type\u003d\"email\" id\u003d\"email-in\" class\u003d\"w-full bg-slate-100 dark:bg-slate-800 rounded-2xl px-6 py-4 mb-4 text-sm font-bold outline-none\" placeholder\u003d\"Email PIC\"\u003e\n      \u003cbutton onclick\u003d\"doLogin()\" class\u003d\"w-full bg-red-600 text-white font-black py-4 rounded-2xl hover:scale-105 active:scale-95 transition-all\"\u003eAUTHENTICATE\u003c/button\u003e\n    \u003c/div\u003e\n  \u003c/div\u003e\n\n  \u003caside id\u003d\"sidebar\" class\u003d\"sidebar card border-r h-full flex flex-col no-print relative\"\u003e\n    \u003cbutton onclick\u003d\"toggleSide()\" class\u003d\"absolute -right-3 top-10 bg-red-600 text-white rounded-full w-6 h-6 flex items-center justify-center text-[10px] z-50\"\u003e\u003ci class\u003d\"fas fa-chevron-left\" id\u003d\"side-icon\"\u003e\u003c/i\u003e\u003c/button\u003e\n    \n    \u003cdiv class\u003d\"p-6\"\u003e\n      \u003cdiv class\u003d\"flex items-center gap-3 mb-8\"\u003e\n        \u003cdiv class\u003d\"w-10 h-10 bg-red-600 rounded-xl flex items-center justify-center shrink-0 shadow-lg shadow-red-500/30\"\u003e\u003ci class\u003d\"fas fa-box-open text-white\"\u003e\u003c/i\u003e\u003c/div\u003e\n        \u003cspan class\u003d\"hide-text font-black text-xl tracking-tighter italic\"\u003eProject DD\u003c/span\u003e\n      \u003c/div\u003e\n      \u003cnav class\u003d\"space-y-1\"\u003e\n        \u003cbutton onclick\u003d\"switchTab(\u0027under90\u0027)\" id\u003d\"btn-u90\" class\u003d\"w-full flex items-center gap-4 p-3.5 rounded-xl bg-slate-900 text-white font-bold text-[11px]\"\u003e\u003ci class\u003d\"fas fa-exclamation-triangle\"\u003e\u003c/i\u003e \u003cspan class\u003d\"hide-text\"\u003eData Kritis\u003c/span\u003e\u003c/button\u003e\n        \u003cbutton onclick\u003d\"switchTab(\u0027over90\u0027)\" id\u003d\"btn-o90\" class\u003d\"w-full flex items-center gap-4 p-3.5 rounded-xl text-slate-400 font-bold text-[11px] hover:bg-slate-50\"\u003e\u003ci class\u003d\"fas fa-check-circle\"\u003e\u003c/i\u003e \u003cspan class\u003d\"hide-text\"\u003eData Aman\u003c/span\u003e\u003c/button\u003e\n      \u003c/nav\u003e\n      \u003cdiv class\u003d\"mt-8 hide-text space-y-4\"\u003e\n        \u003cp class\u003d\"text-[9px] font-black text-slate-400 uppercase tracking-widest\"\u003eLive Promo Statistics\u003c/p\u003e\n        \u003cdiv class\u003d\"grid grid-cols-2 gap-2 text-[10px] font-black\"\u003e\n          \u003cbutton onclick\u003d\"setFilter(\u002730% OFF\u0027)\" class\u003d\"p-3 rounded-xl bg-blue-50 text-blue-600 border border-blue-100\"\u003e30% \u003cspan id\u003d\"s30\"\u003e0\u003c/span\u003e\u003c/button\u003e\n          \u003cbutton onclick\u003d\"setFilter(\u002750% OFF\u0027)\" class\u003d\"p-3 rounded-xl bg-orange-50 text-orange-600 border border-orange-100\"\u003e50% \u003cspan id\u003d\"s50\"\u003e0\u003c/span\u003e\u003c/button\u003e\n          \u003cbutton onclick\u003d\"setFilter(\u002770% OFF\u0027)\" class\u003d\"p-3 rounded-xl bg-red-50 text-red-600 border border-red-100\"\u003e70% \u003cspan id\u003d\"s70\"\u003e0\u003c/span\u003e\u003c/button\u003e\n          \u003cbutton onclick\u003d\"setFilter(\u0027TARIK\u0027)\" class\u003d\"p-3 rounded-xl bg-slate-900 text-white\"\u003eTRK \u003cspan id\u003d\"st\"\u003e0\u003c/span\u003e\u003c/button\u003e\n        \u003c/div\u003e\n      \u003c/div\u003e\n    \u003c/div\u003e\n\n    \u003cdiv class\u003d\"mt-auto p-6 space-y-4\"\u003e\n      \u003cdiv class\u003d\"hide-text\"\u003e\n        \u003cp class\u003d\"text-[9px] font-black text-slate-400 uppercase mb-3\"\u003eTindakan Terakhir\u003c/p\u003e\n        \u003cdiv id\u003d\"action-list\" class\u003d\"space-y-2 max-h-32 overflow-y-auto\"\u003e\u003c/div\u003e\n      \u003c/div\u003e\n      \u003cbutton onclick\u003d\"toggleTheme()\" class\u003d\"w-full flex items-center gap-4 p-3 rounded-xl text-[11px] font-bold hover:bg-slate-50\"\u003e\u003ci class\u003d\"fas fa-moon\"\u003e\u003c/i\u003e \u003cspan class\u003d\"hide-text\"\u003eMode Layar\u003c/span\u003e\u003c/button\u003e\n      \u003cbutton onclick\u003d\"logout()\" class\u003d\"w-full flex items-center gap-4 p-3 rounded-xl text-[11px] font-bold text-red-500 hover:bg-red-50\"\u003e\u003ci class\u003d\"fas fa-power-off\"\u003e\u003c/i\u003e \u003cspan class\u003d\"hide-text\"\u003eLog Out\u003c/span\u003e\u003c/button\u003e\n    \u003c/div\u003e\n  \u003c/aside\u003e\n\n  \u003cmain class\u003d\"flex-1 flex flex-col overflow-hidden\"\u003e\n    \u003cheader class\u003d\"p-4 md:p-6 flex flex-col md:flex-row justify-between items-center no-print border-b card gap-4\"\u003e\n      \u003cdiv class\u003d\"flex items-center gap-4 w-full md:w-auto\"\u003e\n        \u003ch2 class\u003d\"text-xl font-black uppercase italic\" id\u003d\"header-title\"\u003eMonitoring\u003c/h2\u003e\n        \u003cdiv class\u003d\"relative flex-1\"\u003e\n          \u003cinput type\u003d\"text\" id\u003d\"search-box\" onkeyup\u003d\"renderTable()\" placeholder\u003d\"Cari barcode/produk...\" class\u003d\"bg-slate-100 dark:bg-slate-800 rounded-xl px-10 py-3 text-xs font-bold outline-none w-full md:w-64 focus:ring-2 focus:ring-red-600 transition-all\"\u003e\n          \u003ci class\u003d\"fas fa-search absolute left-4 top-4 text-slate-400 text-[10px]\"\u003e\u003c/i\u003e\n        \u003c/div\u003e\n      \u003c/div\u003e\n      \u003cdiv class\u003d\"flex gap-2 w-full md:w-auto justify-end\"\u003e\n        \u003cbutton onclick\u003d\"window.print()\" class\u003d\"bg-black text-white px-5 py-3 rounded-xl text-[10px] font-black shadow-lg\"\u003ePRINT PDF\u003c/button\u003e\n        \u003cdiv id\u003d\"sync-box\" class\u003d\"w-11 h-11 card border rounded-xl flex items-center justify-center shadow-sm\"\u003e\u003ci class\u003d\"fas fa-sync-alt text-slate-300\"\u003e\u003c/i\u003e\u003c/div\u003e\n      \u003c/div\u003e\n    \u003c/header\u003e\n\n    \u003csection class\u003d\"flex-1 overflow-y-auto p-4 md:p-6 flex flex-col lg:flex-row gap-6\"\u003e\n      \u003cdiv class\u003d\"flex-1\"\u003e\n        \u003cdiv class\u003d\"card rounded-3xl border shadow-sm overflow-hidden overflow-x-auto\"\u003e\n          \u003ctable class\u003d\"w-full text-left text-[11px]\"\u003e\n            \u003cthead class\u003d\"bg-slate-50/50 dark:bg-slate-800/50 border-b text-[9px] font-black uppercase text-slate-400\"\u003e\n              \u003ctr\u003e\n                \u003cth class\u003d\"px-6 py-5\"\u003eDetail Produk\u003c/th\u003e\n                \u003cth class\u003d\"px-4 py-5 text-center\"\u003eQty\u003c/th\u003e\n                \u003cth class\u003d\"px-4 py-5 text-center\"\u003eH-Exp\u003c/th\u003e\n                \u003cth class\u003d\"px-6 py-5 text-center\"\u003eHarga Hybrid\u003c/th\u003e\n                \u003cth class\u003d\"px-6 py-5 text-center no-print\"\u003eTindakan\u003c/th\u003e\n              \u003c/tr\u003e\n            \u003c/thead\u003e\n            \u003ctbody id\u003d\"table-body\" class\u003d\"divide-y divide-slate-100 dark:divide-slate-800 font-bold\"\u003e\u003c/tbody\u003e\n          \u003c/table\u003e\n        \u003c/div\u003e\n      \u003c/div\u003e\n\n      \u003cdiv class\u003d\"w-full lg:w-80 space-y-6 no-print\"\u003e\n        \u003cdiv class\u003d\"card p-6 rounded-3xl border shadow-sm\"\u003e\n          \u003cp class\u003d\"text-[10px] font-black uppercase mb-4 opacity-50\"\u003eChart Kategori (CAT3)\u003c/p\u003e\n          \u003ccanvas id\u003d\"donutChart\" height\u003d\"220\"\u003e\u003c/canvas\u003e\n        \u003c/div\u003e\n        \u003cdiv class\u003d\"card p-6 rounded-3xl border shadow-sm\"\u003e\n          \u003cp class\u003d\"text-[10px] font-black uppercase mb-4 opacity-50\"\u003eTrend Diskon (Batang)\u003c/p\u003e\n          \u003ccanvas id\u003d\"barChart\" height\u003d\"180\"\u003e\u003c/canvas\u003e\n        \u003c/div\u003e\n      \u003c/div\u003e\n    \u003c/section\u003e\n  \u003c/main\u003e\n\n  \u003cscript\u003e\n    let db \u003d { under90: [], over90: [], stats: {}, chartCat3: {} };\n    let activeTab \u003d \u0027under90\u0027;\n    let filterLabel \u003d \u0027\u0027;\n    let charts \u003d {};\n\n    window.onload \u003d () \u003d\u003e {\n      if(localStorage.getItem(\u0027coreV15Login\u0027)) {\n        document.getElementById(\u0027login-overlay\u0027).style.display \u003d \u0027none\u0027;\n        init();\n      }\n    };\n\n    function doLogin() {\n      const email \u003d document.getElementById(\u0027email-in\u0027).value;\n      google.script.run.withSuccessHandler(res \u003d\u003e {\n        if(res.success) { localStorage.setItem(\u0027coreV15Login\u0027, res.email); location.reload(); }\n        else alert(\"Akses Ditolak!\");\n      }).checkLogin(email);\n    }\n\n    function init() {\n      fetchData();\n      setInterval(fetchData, 30000); // AUTO SYNC 30 DETIK\n    }\n\n    function fetchData() {\n      const icon \u003d document.querySelector(\u0027.fa-sync-alt\u0027);\n      icon.classList.add(\u0027fa-spin\u0027);\n      google.script.run.withSuccessHandler(res \u003d\u003e {\n        db \u003d res;\n        updateUI();\n        icon.classList.remove(\u0027fa-spin\u0027);\n      }).getDashboardData();\n    }\n\n    function updateUI() {\n      document.getElementById(\u0027s30\u0027).innerText \u003d db.stats.p30;\n      document.getElementById(\u0027s50\u0027).innerText \u003d db.stats.p50;\n      document.getElementById(\u0027s70\u0027).innerText \u003d db.stats.p70;\n      document.getElementById(\u0027st\u0027).innerText \u003d db.stats.tarik;\n      renderTable();\n      renderCharts();\n    }\n\n    function renderTable() {\n      const q \u003d document.getElementById(\u0027search-box\u0027).value.toLowerCase();\n      const body \u003d document.getElementById(\u0027table-body\u0027);\n      body.innerHTML \u003d \"\";\n      \n      let list \u003d db[activeTab];\n      if(filterLabel) list \u003d list.filter(i \u003d\u003e i.label \u003d\u003d\u003d filterLabel);\n      if(q) list \u003d list.filter(i \u003d\u003e i.nama.toLowerCase().includes(q) || i.barcode.includes(q));\n\n      list.forEach(i \u003d\u003e {\n        const sColor \u003d i.sisa \u003c\u003d 0 ? \"bg-red-600 text-white px-2 py-0.5 rounded\" : (i.sisa \u003c\u003d 30 ? \"text-red-600 animate-pulse\" : \"text-slate-400\");\n        body.innerHTML +\u003d `\n          \u003ctr class\u003d\"hover:bg-slate-50/50 dark:hover:bg-slate-800/50 transition border-b animate__animated animate__fadeIn\"\u003e\n            \u003ctd class\u003d\"px-6 py-4\"\u003e\n              \u003cdiv class\u003d\"flex items-center gap-2\"\u003e\n                ${i.isNew ? \u0027\u003cspan class\u003d\"bg-blue-600 text-white text-[7px] px-1.5 py-0.5 rounded-full animate-bounce\"\u003eNEW\u003c/span\u003e\u0027 : \u0027\u0027}\n                \u003cspan class\u003d\"uppercase text-slate-900 dark:text-white truncate max-w-[150px]\"\u003e${i.nama}\u003c/span\u003e\n              \u003c/div\u003e\n              \u003cdiv class\u003d\"text-[8px] opacity-40 font-mono mt-1\"\u003e${i.barcode} | Exp: ${i.exp}\u003c/div\u003e\n            \u003c/td\u003e\n            \u003ctd class\u003d\"px-4 py-4 text-center text-sm font-black\"\u003e${i.qty}\u003c/td\u003e\n            \u003ctd class\u003d\"px-4 py-4 text-center\"\u003e\u003cspan class\u003d\"text-[9px] font-black ${sColor}\"\u003e${i.sisa} HARI\u003c/span\u003e\u003c/td\u003e\n            \u003ctd class\u003d\"px-6 py-4 text-center\"\u003e\n              \u003cdiv class\u003d\"text-[8px] opacity-30 line-through\"\u003eRp ${Math.round(i.hNormal).toLocaleString()}\u003c/div\u003e\n              \u003cdiv class\u003d\"text-red-600 font-black\"\u003eRp ${Math.round(i.hPromo).toLocaleString()}\u003c/div\u003e\n            \u003c/td\u003e\n            \u003ctd class\u003d\"px-6 py-4 text-center no-print\"\u003e\n              \u003cselect onchange\u003d\"handleAct(${i.row}, \u0027${i.nama}\u0027, this)\" class\u003d\"bg-slate-100 dark:bg-slate-800 px-3 py-2.5 rounded-xl text-[9px] font-black outline-none border-none cursor-pointer\"\u003e\n                \u003coption value\u003d\"\"\u003eAKSI\u003c/option\u003e\n                \u003coption value\u003d\"RTV\"\u003eRTV\u003c/option\u003e\n                \u003coption value\u003d\"SOLD\"\u003eSOLD\u003c/option\u003e\n                \u003coption value\u003d\"MARKDOWN\"\u003eMARKDOWN\u003c/option\u003e\n              \u003c/select\u003e\n            \u003c/td\u003e\n          \u003c/tr\u003e`;\n      });\n    }\n\n    function handleAct(row, nama, el) {\n      if(!el.value) return;\n      if(!confirm(\"⚠️ Pastikan kembali tindakan \u0027\" + el.value + \"\u0027 sudah benar?\")) { el.value\u003d\"\"; return; }\n      const act \u003d el.value;\n      google.script.run.withSuccessHandler(() \u003d\u003e {\n        const log \u003d document.getElementById(\u0027action-list\u0027);\n        const d \u003d document.createElement(\u0027div\u0027);\n        d.className \u003d \"p-2 rounded-xl bg-slate-100 dark:bg-slate-800 text-[9px] border-l-4 border-red-600 animate__animated animate__fadeInLeft\";\n        d.innerHTML \u003d `\u003cstrong\u003e${act}\u003c/strong\u003e - ${nama.substring(0,12)}...`;\n        log.prepend(d);\n        fetchData();\n      }).moveAction(row, act, localStorage.getItem(\u0027coreV15Login\u0027));\n    }\n\n    function renderCharts() {\n      const dData \u003d { type: \u0027doughnut\u0027, data: { labels: Object.keys(db.chartCat3), datasets: [{ data: Object.values(db.chartCat3), backgroundColor: [\u0027#ef4444\u0027,\u0027#3b82f6\u0027,\u0027#f59e0b\u0027,\u0027#10b981\u0027,\u0027#8b5cf6\u0027,\u0027#06b6d4\u0027] }] }, options: { plugins: { legend: { display: false } }, cutout: \u002780%\u0027 } };\n      const bData \u003d { type: \u0027bar\u0027, data: { labels: [\u002730%\u0027,\u002750%\u0027,\u002770%\u0027,\u0027TRK\u0027], datasets: [{ data: [db.stats.p30, db.stats.p50, db.stats.p70, db.stats.tarik], backgroundColor: \u0027#ef4444\u0027, borderRadius: 8 }] }, options: { plugins: { legend: { display: false } }, scales: { y: { display: false } } } };\n      if(charts.d) charts.d.destroy(); if(charts.b) charts.b.destroy();\n      charts.d \u003d new Chart(document.getElementById(\u0027donutChart\u0027), dData);\n      charts.b \u003d new Chart(document.getElementById(\u0027barChart\u0027), bData);\n    }\n\n    function toggleSide() {\n      document.getElementById(\u0027sidebar\u0027).classList.toggle(\u0027collapsed\u0027);\n      document.getElementById(\u0027side-icon\u0027).classList.toggle(\u0027fa-chevron-right\u0027);\n    }\n    function toggleTheme() { document.body.classList.toggle(\u0027dark\u0027); }\n    function switchTab(t) { activeTab \u003d t; filterLabel \u003d \u0027\u0027; fetchData(); }\n    function setFilter(l) { filterLabel \u003d l; renderTable(); }\n    function logout() { localStorage.clear(); location.reload(); }\n  \u003c/script\u003e\n\u003c/body\u003e\n\u003c/html\u003e"}]}